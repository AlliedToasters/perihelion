{{!< default}}

{{#post}}
{{#has tag="tbc"}}

{{!-- "To Be Continued" sentinel page --}}
<article class="container tbc-page">
    <div class="tbc-page-inner">
        <div class="tbc-rule"></div>
        <p class="tbc-label">// TO BE CONTINUED</p>
        <div class="tbc-page-body">
            {{content}}
        </div>
    </div>

    {{!-- Navigation back (no "next" from here) --}}
    <nav class="chapter-nav">
        <div class="chapter-nav-prev">
            {{#prev_post in="tag.chapter"}}
            <a href="{{url}}">&larr; {{title}}</a>
            {{/prev_post}}
        </div>
        <div class="chapter-nav-home">
            <a href="{{@site.url}}">Contents</a>
        </div>
        <div class="chapter-nav-next"></div>
    </nav>
</article>

{{else}}

{{!-- Reading progress bar --}}
<div class="progress-bar" id="progress-bar"></div>

<article class="container post-container">

    <header class="post-header">
        {{!-- Chapter number from ch-XX tag --}}
        <div class="post-meta">
            {{#foreach tags from="2" to="2"}}
                <span class="post-chapter-number">{{name}}</span>
            {{/foreach}}
        </div>
        <h1 class="post-title">{{title}}</h1>
        {{#if custom_excerpt}}
        <p class="post-excerpt">{{custom_excerpt}}</p>
        {{/if}}
    </header>

    {{!-- Top navigation --}}
    {{> chapter-nav}}

    <div class="post-body">
        {{content}}
    </div>

    {{!-- Bottom navigation --}}
    {{> chapter-nav}}

</article>

{{/has}}
{{/post}}
